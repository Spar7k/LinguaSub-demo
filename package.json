{
  "name": "linguasub",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "backend:bundle": "py -3 -m PyInstaller --noconfirm --distpath .pyinstaller/dist --workpath .pyinstaller/build linguasub-backend.spec",
    "backend:dev": "py -3 backend/run_server.py",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "release:prepare": "powershell -ExecutionPolicy Bypass -File scripts/prepare-release-runtime.ps1",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "npm.cmd run release:prepare && tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  }
}
