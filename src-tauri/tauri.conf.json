{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LinguaSub",
  "version": "0.1.0",
  "identifier": "com.linguasub.desktop",
  "build": {
    "beforeDevCommand": "npm.cmd run dev",
    "beforeBuildCommand": "npm.cmd run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LinguaSub",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "maximizable": true,
        "maximized": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["main-capability"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "externalBin": ["binaries/linguasub-backend"],
    "resources": ["resources/runtime"],
    "icon": ["icons/icon.ico"],
    "windows": {
      "nsis": {
        "installerHooks": "./windows/hooks.nsh"
      }
    }
  }
}
